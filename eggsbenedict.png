<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contact — Vintage Cafe | Everett, WA</title>
  <meta name="description" content="Get in touch with Vintage Cafe — find our hours, location, phone number, and send us a message. Located at 1510 Hewitt Ave, Everett, WA.">

  <meta property="og:title" content="Contact — Vintage Cafe | Everett, WA">
  <meta property="og:description" content="Visit us at 1510 Hewitt Ave, Everett WA. Open daily 7AM — 3PM.">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://picsum.photos/seed/vintagecafe-contact-og/1200/630.jpg">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>

  <!-- Preloader -->
  <div class="preloader" aria-hidden="true">
    <div class="preloader-brand">Contact</div>
    <div class="preloader-line"></div>
  </div>

  <!-- Navigation -->
  <nav class="navbar" role="navigation" aria-label="Main navigation">
    <div class="navbar-inner">
      <a href="index.html" class="navbar-logo">Vintage<span>.</span></a>
      <div class="navbar-links">
        <a href="index.html" class="navbar-link">Home</a>
        <a href="about.html" class="navbar-link">Our Story</a>
        <a href="services.html" class="navbar-link">Menu</a>
        <a href="contact.html" class="navbar-link active">Contact</a>
      </div>
      <div class="navbar-actions">
        <button class="cart-btn" aria-label="Open cart">
          <i data-lucide="shopping-bag" style="width:20px;height:20px;"></i>
          <span class="cart-badge">0</span>
        </button>
        <button class="menu-toggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" role="dialog" aria-label="Mobile navigation">
    <a href="index.html" class="mobile-menu-link">Home</a>
    <a href="about.html" class="mobile-menu-link">Our Story</a>
    <a href="services.html" class="mobile-menu-link">Menu</a>
    <a href="contact.html" class="mobile-menu-link">Contact</a>
    <div class="mobile-menu-footer">1510 Hewitt Ave, Everett WA</div>
  </div>

  <!-- Page Hero -->
  <section class="page-hero" style="min-height:35vh;">
    <div class="page-hero-bg">
      <img src="contacthero.png" alt="Vintage Cafe storefront" loading="eager">
    </div>
    <div class="page-hero-content">
      <h1 class="page-hero-title">Get In <em>Touch</em></h1>
      <p class="page-hero-subtitle">We'd love to hear from you — or see you at the table.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section">
    <div class="section-container">
      <div class="contact-grid">

        <!-- Left Column: Info + Hours -->
        <div>
          <!-- Contact Info Cards -->
          <div style="display:flex;flex-direction:column;gap:1rem;margin-bottom:2.5rem;">
            <div class="contact-info-card reveal">
              <div class="contact-info-icon">
                <i data-lucide="map-pin" style="width:20px;height:20px;"></i>
              </div>
              <div>
                <div class="contact-info-label">Address</div>
                <div class="contact-info-value">1510 Hewitt Ave, Everett, WA 98201</div>
              </div>
            </div>
            <div class="contact-info-card reveal" data-delay="0.1">
              <div class="contact-info-icon">
                <i data-lucide="phone" style="width:20px;height:20px;"></i>
              </div>
              <div>
                <div class="contact-info-label">Phone</div>
                <a href="tel:+14255551234" class="contact-info-value" style="color:var(--caramel);">(425) 555-1234</a>
              </div>
            </div>
            <div class="contact-info-card reveal" data-delay="0.2">
              <div class="contact-info-icon">
                <i data-lucide="mail" style="width:20px;height:20px;"></i>
              </div>
              <div>
                <div class="contact-info-label">Email</div>
                <a href="mailto:hello@vintagecafe.com" class="contact-info-value" style="color:var(--caramel);">hello@vintagecafe.com</a>
              </div>
            </div>
          </div>

          <!-- Hours -->
          <div class="reveal" data-delay="0.3">
            <h3 class="font-heading" style="font-size:1.25rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.5rem;">
              <span style="color:var(--caramel);"><i data-lucide="clock" style="width:20px;height:20px;vertical-align:middle;"></i></span>
              Hours
            </h3>
            <div style="background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--beige);padding:1.25rem;">
              <div class="hours-list">
                <div class="hours-row">
                  <span class="hours-day">Monday</span>
                  <span class="hours-time">7:00 AM — 3:00 PM</span>
                </div>
                <div class="hours-row">
                  <span class="hours-day">Tuesday</span>
                  <span class="hours-time">7:00 AM — 3:00 PM</span>
                </div>
                <div class="hours-row">
                  <span class="hours-day">Wednesday</span>
                  <span class="hours-time">7:00 AM — 3:00 PM</span>
                </div>
                <div class="hours-row">
                  <span class="hours-day">Thursday</span>
                  <span class="hours-time">7:00 AM — 3:00 PM</span>
                </div>
                <div class="hours-row">
                  <span class="hours-day">Friday</span>
                  <span class="hours-time">7:00 AM — 3:00 PM</span>
                </div>
                <div class="hours-row">
                  <span class="hours-day">Saturday</span>
                  <span class="hours-time">7:00 AM — 3:00 PM</span>
                </div>
                <div class="hours-row">
                  <span class="hours-day">Sunday</span>
                  <span class="hours-time">7:00 AM — 3:00 PM</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Column: Contact Form -->
        <div>
          <div class="contact-form reveal" data-delay="0.2">
            <h3>Send a Message</h3>
            <form id="contact-form" novalidate>
              <div class="form-group">
                <label for="contact-name">Name</label>
                <input type="text" id="contact-name" name="name" placeholder="Your full name" required>
                <div class="form-error"></div>
              </div>
              <div class="form-group">
                <label for="contact-email">Email</label>
                <input type="email" id="contact-email" name="email" placeholder="your@email.com" required>
                <div class="form-error"></div>
              </div>
              <div class="form-group">
                <label for="contact-subject">Subject</label>
                <select id="contact-subject" name="subject">
                  <option value="general">General Inquiry</option>
                  <option value="catering">Catering Request</option>
                  <option value="feedback">Feedback</option>
                  <option value="events">Private Events</option>
                </select>
              </div>
              <div class="form-group">
                <label for="contact-message">Message</label>
                <textarea id="contact-message" name="message" placeholder="How can we help?" rows="5" required></textarea>
                <div class="form-error"></div>
              </div>
              <button type="submit" class="btn btn-dark" style="width:100%;">Send Message</button>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="section" style="padding-top:0;">
    <div class="section-container">
      <div class="section-header reveal">
        <div class="section-label">
          <span class="section-label-line"></span>
          Find Us
        </div>
        <h2 class="section-title">Our <em>Location</em></h2>
      </div>
      <div class="map-wrapper reveal" data-delay="0.2">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2678.6!2d-122.2016!3d47.9786!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1510+Hewitt+Ave%2C+Everett%2C+WA!5e0!3m2!1sen!2sus!4v1" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Vintage Cafe location map"></iframe>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section section">
    <div class="section-container" style="position:relative;z-index:1;">
      <h2 class="cta-heading reveal">Hungry <em>Yet</em>?</h2>
      <p class="cta-desc reveal" data-delay="0.1">Skip the line — order ahead for pickup or just come on in. We'll save you a seat.</p>
      <div class="reveal" data-delay="0.2" style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center;">
        <a href="services.html" class="btn btn-primary">Order Now</a>
        <a href="tel:+14255551234" class="btn btn-outline" style="border-color:rgba(255,248,240,0.3);color:var(--cream);">Call Us</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <div class="footer-brand">Vintage<span>.</span></div>
          <p class="footer-tagline">A casual gathering place since 1892. Serving global-inspired comfort food in the heart of Everett, Washington.</p>
          <div class="footer-social">
            <a href="https://instagram.com/vintagecafe" target="_blank" rel="noopener" class="footer-social-link" aria-label="Instagram">
              <i data-lucide="instagram" style="width:18px;height:18px;"></i>
            </a>
            <a href="https://facebook.com/vintagecafe" target="_blank" rel="noopener" class="footer-social-link" aria-label="Facebook">
              <i data-lucide="facebook" style="width:18px;height:18px;"></i>
            </a>
            <a href="https://yelp.com/biz/vintage-cafe-everett" target="_blank" rel="noopener" class="footer-social-link" aria-label="Yelp">
              <i data-lucide="star" style="width:18px;height:18px;"></i>
            </a>
          </div>
        </div>
        <div>
          <div class="footer-heading">Navigate</div>
          <div class="footer-links">
            <a href="index.html" class="footer-link">Home</a>
            <a href="about.html" class="footer-link">Our Story</a>
            <a href="services.html" class="footer-link">Menu</a>
            <a href="contact.html" class="footer-link">Contact</a>
          </div>
        </div>
        <div>
          <div class="footer-heading">Hours</div>
          <div class="footer-links">
            <span class="footer-link">Mon — Sun</span>
            <span class="footer-link">7:00 AM — 3:00 PM</span>
          </div>
        </div>
        <div>
          <div class="footer-heading">Contact</div>
          <div class="footer-links">
            <a href="tel:+14255551234" class="footer-link">(425) 555-1234</a>
            <a href="mailto:hello@vintagecafe.com" class="footer-link">hello@vintagecafe.com</a>
            <span class="footer-link">1510 Hewitt Ave, Everett WA</span>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="footer-copy">2025 Vintage Cafe. All rights reserved.</span>
        <span class="footer-dw33py">Engineered in motion — <a href="https://dw33py.netlify.app" target="_blank" rel="noopener">Dw33pY</a></span>
      </div>
    </div>
  </footer>

  <!-- Cart Drawer -->
  <div class="cart-overlay"></div>
  <div class="cart-drawer" role="dialog" aria-label="Shopping cart">
    <div class="cart-header">
      <h3>Your Order</h3>
      <button class="cart-close" aria-label="Close cart">
        <i data-lucide="x" style="width:20px;height:20px;"></i>
      </button>
    </div>
    <div class="cart-body"></div>
    <div class="cart-footer">
      <div class="cart-total">
        <span class="cart-total-label">Total</span>
        <span class="cart-total-amount">$0.00</span>
      </div>
      <button class="cart-checkout-btn">Place Order</button>
    </div>
  </div>

  <!-- Checkout Modal -->
  <div class="checkout-modal-overlay">
    <div class="checkout-modal">
      <div class="checkout-modal-header">
        <h3>Complete Order</h3>
        <button class="checkout-modal-close cart-close" aria-label="Close checkout">
          <i data-lucide="x" style="width:20px;height:20px;"></i>
        </button>
      </div>
      
      <!-- Order Summary -->
      <div class="checkout-summary">
        <div class="checkout-summary-title">Your Items</div>
        <div class="checkout-summary-list"></div>
        <div class="checkout-summary-divider"></div>
        <div class="checkout-summary-item">
          <span class="checkout-summary-item-name" style="font-weight:700;">Total</span>
          <span class="checkout-summary-total" style="font-family:var(--font-heading);font-size:1.1rem;font-weight:700;color:var(--caramel);">$0.00</span>
        </div>
      </div>
      
      <form id="checkout-form" class="checkout-form">
        <div class="form-group">
          <label for="checkout-name">Name</label>
          <input type="text" id="checkout-name" name="name" placeholder="Your full name" required>
          <div class="form-error"></div>
        </div>
        <div class="form-group">
          <label for="checkout-phone">Phone</label>
          <input type="tel" id="checkout-phone" name="phone" placeholder="(425) 555-0000" required>
          <div class="form-error"></div>
        </div>
        <div class="form-group">
          <label for="checkout-time">Pickup Time</label>
          <select id="checkout-time" name="time">
            <option value="asap">As soon as possible</option>
            <option value="30min">In 30 minutes</option>
            <option value="1hr">In 1 hour</option>
            <option value="90min">In 1.5 hours</option>
          </select>
        </div>
        <div class="form-group">
          <label for="checkout-notes">Special Instructions</label>
          <textarea id="checkout-notes" name="notes" placeholder="Any allergies or preferences..." rows="3"></textarea>
        </div>
        <button type="submit" class="checkout-submit">Confirm Order</button>
      </form>
      <div class="order-confirmation">
        <div class="order-confirmation-icon">
          <i data-lucide="check" style="width:32px;height:32px;"></i>
        </div>
        <h3>Order Placed!</h3>
        <p>We're preparing your order. We'll call you shortly to confirm.</p>
      </div>
    </div>
  </div>

  <!-- Floating Buttons -->
  <div class="float-btns">
    <a href="tel:+14255551234" id="float-call" class="float-btn float-call" aria-label="Call Vintage Cafe">
      <i data-lucide="phone" style="width:22px;height:22px;"></i>
    </a>
    <a href="sms:+14255551234?body=Hi%20Vintage%20Cafe!%20I%27d%20like%20to%20place%20an%20order." id="float-text" class="float-btn float-text" aria-label="Text Vintage Cafe">
      <i data-lucide="message-square" style="width:22px;height:22px;"></i>
    </a>
    <button class="float-btn float-top" aria-label="Back to top">
      <i data-lucide="arrow-up" style="width:22px;height:22px;"></i>
    </button>
  </div>
  
  <script src="js/main.js"></script>
</body>
</html>