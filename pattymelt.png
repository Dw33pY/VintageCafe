<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vintage Cafe — Everett's Beloved Cafe Since 1892</title>
  <meta name="description" content="Vintage Cafe in Everett, WA — A casual gathering place since 1892 offering global-inspired comfort food, from classic eggs benedict to poutine and chicken marsala.">

  <meta property="og:title" content="Vintage Cafe — Everett's Beloved Cafe Since 1892">
  <meta property="og:description" content="A casual gathering place since 1892 offering global-inspired comfort food in the heart of Everett, WA.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://vintagecafe.com">
  <meta property="og:image" content="https://picsum.photos/seed/vintagecafe-og/1200/630.jpg">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Vintage Cafe — Since 1892">
  <meta name="twitter:description" content="Everett's beloved cafe serving global-inspired comfort food.">

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "CafeOrCoffeeShop",
    "name": "Vintage Cafe",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "1510 Hewitt Ave",
      "addressLocality": "Everett",
      "addressRegion": "WA",
      "addressCountry": "US"
    },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.4", "reviewCount": "1723" },
    "priceRange": "$20-30",
    "servesCuisine": ["Cafe", "American", "Global"],
    "openingHours": "Mo-Su 07:00-15:00"
  }
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>

  <!-- Preloader -->
  <div class="preloader" aria-hidden="true">
    <div class="preloader-brand">Vintage Cafe</div>
    <div class="preloader-line"></div>
  </div>

  <!-- Navigation -->
  <nav class="navbar" role="navigation" aria-label="Main navigation">
    <div class="navbar-inner">
      <a href="index.html" class="navbar-logo">Vintage<span>.</span></a>
      <div class="navbar-links">
        <a href="index.html" class="navbar-link active">Home</a>
        <a href="about.html" class="navbar-link">Our Story</a>
        <a href="services.html" class="navbar-link">Menu</a>
        <a href="contact.html" class="navbar-link">Contact</a>
      </div>
      <div class="navbar-actions">
        <button class="cart-btn" aria-label="Open cart">
          <i data-lucide="shopping-bag" style="width:20px;height:20px;"></i>
          <span class="cart-badge">0</span>
        </button>
        <button class="menu-toggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" role="dialog" aria-label="Mobile navigation">
    <a href="index.html" class="mobile-menu-link">Home</a>
    <a href="about.html" class="mobile-menu-link">Our Story</a>
    <a href="services.html" class="mobile-menu-link">Menu</a>
    <a href="contact.html" class="mobile-menu-link">Contact</a>
    <div class="mobile-menu-footer">1510 Hewitt Ave, Everett WA</div>
  </div>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-bg">
      <img src="homehero.jpeg" alt="Vintage Cafe interior" loading="eager">
    </div>
    <div class="hero-content">
            <div class="status-badge" aria-live="polite"></div>
      <div class="hero-tag">
        <span class="hero-tag-line"></span>
        Everett, WA — Est. 1892
      </div>
      <h1 class="hero-title">Vintage<br><em>Cafe</em></h1>
      <p class="hero-subtitle">A casual gathering place serving global-inspired comfort food in the heart of Everett for over a century.</p>
      <div class="hero-actions">
        <a href="services.html" class="btn btn-primary">Order Now</a>
        <a href="about.html" class="btn btn-outline">Our Story</a>
      </div>
    </div>
  </section>

  <!-- Featured Dishes — Infinite Marquee -->
  <section class="section dishes-section" id="featured">
    <div class="section-container">
      <div class="section-header reveal">
        <div class="section-label">
          <span class="section-label-line"></span>
          From Our Kitchen
        </div>
        <h2 class="section-title">Signature <em>Dishes</em></h2>
        <p class="section-desc">Crafted with care and served with warmth — the flavors that have kept Everett coming back for generations.</p>
      </div>
    </div>
    
    <!-- Infinite Scrolling Marquee (full-width) -->
    <div class="dishes-marquee-wrapper">
      <div class="dishes-marquee">
        
        <!-- SET 1 -->
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="eggsbenedict.png" alt="Eggs Benedict" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Eggs Benedict</h3>
            <p class="dish-card-desc">Traditional ham or Florentine with hollandaise and potatoes</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="frenchtoast.png" alt="Vintage French Toast" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Vintage French Toast</h3>
            <p class="dish-card-desc">Our signature French toast with seasonal accompaniments</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="chickenfried.png" alt="Chicken Fried Steak" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Chicken Fried Steak</h3>
            <p class="dish-card-desc">Hand-breaded steak with country gravy and homestyle sides</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="poutine.png" alt="Poutine" loading="lazy">
            <div class="dish-card-price">$16</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Poutine</h3>
            <p class="dish-card-desc">Crispy fries topped with rich gravy and cheese curds</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="pattymelt.png" alt="Patty Melt" loading="lazy">
            <div class="dish-card-price">$16</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Patty Melt</h3>
            <p class="dish-card-desc">Ground sirloin with caramelized onions and Swiss on rye</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="biscuits.png" alt="Biscuits and Gravy" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Biscuits &amp; Gravy</h3>
            <p class="dish-card-desc">Homemade sausage gravy over fresh-baked biscuits</p>
          </div>
        </div>
        
        <!-- SET 2 (Duplicate for seamless loop) -->
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="eggsbenedict.png" alt="Eggs Benedict" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Eggs Benedict</h3>
            <p class="dish-card-desc">Traditional ham or Florentine with hollandaise and potatoes</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="frenchtoast.png" alt="Vintage French Toast" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Vintage French Toast</h3>
            <p class="dish-card-desc">Our signature French toast with seasonal accompaniments</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="chickenfried.png" alt="Chicken Fried Steak" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Chicken Fried Steak</h3>
            <p class="dish-card-desc">Hand-breaded steak with country gravy and homestyle sides</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="poutine.png" alt="Poutine" loading="lazy">
            <div class="dish-card-price">$16</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Poutine</h3>
            <p class="dish-card-desc">Crispy fries topped with rich gravy and cheese curds</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="pattymelt.png" alt="Patty Melt" loading="lazy">
            <div class="dish-card-price">$16</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Patty Melt</h3>
            <p class="dish-card-desc">Ground sirloin with caramelized onions and Swiss on rye</p>
          </div>
        </div>
        
        <div class="dish-card">
          <div class="dish-card-img-wrapper">
            <img class="dish-card-img" src="biscuits.png" alt="Biscuits and Gravy" loading="lazy">
            <div class="dish-card-price">$20</div>
          </div>
          <div class="dish-card-body">
            <h3 class="dish-card-name">Biscuits &amp; Gravy</h3>
            <p class="dish-card-desc">Homemade sausage gravy over fresh-baked biscuits</p>
          </div>
        </div>
        
      </div>
    </div>
    
    <div class="section-container">
      <div class="reveal" style="margin-top:2.5rem; text-align:center;">
        <a href="services.html" class="btn btn-dark">View Full Menu</a>
      </div>
    </div>
  </section>

  <!-- Heritage Pinned Section -->
  <section class="heritage-section section">
    <div class="heritage-bg-text" aria-hidden="true">1892</div>
    <div class="section-container">
      <div class="heritage-grid">
        <div class="heritage-text reveal">
          <div class="heritage-year">1892</div>
          <h2 class="heritage-heading">A Gathering Place<br>Through <em>Generations</em></h2>
          <p class="heritage-body">For over 130 years, Vintage Cafe has been the heart of Everett — a place where strangers become regulars and regulars become family. What began as a humble kitchen on Hewitt Avenue has evolved into one of the Pacific Northwest's most beloved gathering spots, still serving the same warmth that opened our doors in 1892.</p>
        </div>
        <div class="heritage-image reveal" data-delay="0.2">
          <img src="heritage.jpeg" alt="Vintage Cafe historic interior" loading="lazy">
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section section-dark">
    <div class="section-container">
      <div class="section-header reveal">
        <div class="section-label">
          <span class="section-label-line"></span>
          Guest Voices
        </div>
        <h2 class="section-title section-title-light">What Our <em>Guests</em> Say</h2>
        <p class="section-desc">1,723 reviews and counting — rated 4.4 stars by our community.</p>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card reveal">
          <div class="testimonial-stars">
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
          </div>
          <p class="testimonial-text">"Great experience! The waiter was super friendly and service was quick. I had the Patty Melt with Mac and Cheese — absolutely delicious."</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">K</div>
            <div>
              <div class="testimonial-name">Kelley Meredith</div>
              <div class="testimonial-detail">Local Guide · Lunch</div>
            </div>
          </div>
        </div>
        <div class="testimonial-card reveal" data-delay="0.1">
          <div class="testimonial-stars">
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
          </div>
          <p class="testimonial-text">"Great place for breakfast! Food was amazing and came out fast. Definitely coming back."</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">J</div>
            <div>
              <div class="testimonial-name">J M</div>
              <div class="testimonial-detail">Local Guide · Breakfast</div>
            </div>
          </div>
        </div>
        <div class="testimonial-card reveal" data-delay="0.2">
          <div class="testimonial-stars">
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
          </div>
          <p class="testimonial-text">"The food and service were both outstanding. Highly recommend the Vintage French Toast — it's everything you hope for and more."</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">S</div>
            <div>
              <div class="testimonial-name">Sammie Able</div>
              <div class="testimonial-detail">Local Guide · Breakfast</div>
            </div>
          </div>
        </div>
        <div class="testimonial-card reveal" data-delay="0.3">
          <div class="testimonial-stars">
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
            <i data-lucide="star" style="width:16px;height:16px;fill:currentColor;"></i>
          </div>
          <p class="testimonial-text">"Amazing breakfast spot! The hash browns were perfectly crispy, coffee was great, and the atmosphere is so warm and inviting. We'll definitely be back."</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar">T</div>
            <div>
              <div class="testimonial-name">Traveling Foodie</div>
              <div class="testimonial-detail">Local Guide · Breakfast</div>
            </div>
          </div>
        </div>
