  <!-- Location Preview -->
  <section class="section">
    <div class="section-container">
      <div class="section-header reveal">
        <div class="section-label">
          <span class="section-label-line"></span>
          Find Us
        </div>
        <h2 class="section-title">Visit <em>Us</em></h2>
        <p class="section-desc">1510 Hewitt Ave, Everett, WA — Open daily from 7:00 AM.</p>
      </div>
      <div class="map-wrapper reveal" data-delay="0.2">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2678.6!2d-122.2016!3d47.9786!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1510+Hewitt+Ave%2C+Everett%2C+WA!5e0!3m2!1sen!2sus!4v1" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="Vintage Cafe location map"></iframe>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section section">
    <div class="section-container" style="position:relative;z-index:1;">
      <h2 class="cta-heading reveal">Ready to <em>Taste</em><br>the Tradition?</h2>
      <p class="cta-desc reveal" data-delay="0.1">Order ahead for pickup or join us at the table. Over 130 years of flavor awaits.</p>
      <div class="reveal" data-delay="0.2">
        <a href="services.html" class="btn btn-primary">Order Now</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-inner">
      <div class="footer-grid">
        <div>
          <div class="footer-brand">Vintage<span>.</span></div>
          <p class="footer-tagline">A casual gathering place since 1892. Serving global-inspired comfort food in the heart of Everett, Washington.</p>
          <div class="footer-social">
            <a href="https://instagram.com/vintagecafe" target="_blank" rel="noopener" class="footer-social-link" aria-label="Instagram">
              <i data-lucide="instagram" style="width:18px;height:18px;"></i>
            </a>
            <a href="https://facebook.com/vintagecafe" target="_blank" rel="noopener" class="footer-social-link" aria-label="Facebook">
              <i data-lucide="facebook" style="width:18px;height:18px;"></i>
            </a>
            <a href="https://yelp.com/biz/vintage-cafe-everett" target="_blank" rel="noopener" class="footer-social-link" aria-label="Yelp">
              <i data-lucide="star" style="width:18px;height:18px;"></i>
            </a>
          </div>
        </div>
        <div>
          <div class="footer-heading">Navigate</div>
          <div class="footer-links">
            <a href="index.html" class="footer-link">Home</a>
            <a href="about.html" class="footer-link">Our Story</a>
            <a href="services.html" class="footer-link">Menu</a>
            <a href="contact.html" class="footer-link">Contact</a>
          </div>
        </div>
        <div>
          <div class="footer-heading">Hours</div>
          <div class="footer-links">
            <span class="footer-link">Mon — Sun</span>
            <span class="footer-link">7:00 AM — 3:00 PM</span>
          </div>
        </div>
        <div>
          <div class="footer-heading">Contact</div>
          <div class="footer-links">
            <a href="tel:+14255551234" class="footer-link">(425) 555-1234</a>
            <a href="mailto:hello@vintagecafe.com" class="footer-link">hello@vintagecafe.com</a>
            <span class="footer-link">1510 Hewitt Ave, Everett WA</span>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="footer-copy">2025 Vintage Cafe. All rights reserved.</span>
        <span class="footer-dw33py">Engineered in motion — <a href="https://dw33py.netlify.app" target="_blank" rel="noopener">Dw33pY</a></span>
      </div>
    </div>
  </footer>

  <!-- Cart Drawer -->
  <div class="cart-overlay"></div>
  <div class="cart-drawer" role="dialog" aria-label="Shopping cart">
    <div class="cart-header">
      <h3>Your Order</h3>
      <button class="cart-close" aria-label="Close cart">
        <i data-lucide="x" style="width:20px;height:20px;"></i>
      </button>
    </div>
    <div class="cart-body"></div>
    <div class="cart-footer">
      <div class="cart-total">
        <span class="cart-total-label">Total</span>
        <span class="cart-total-amount">$0.00</span>
      </div>
      <button class="cart-checkout-btn">Place Order</button>
    </div>
  </div>

  <!-- Checkout Modal -->
  <div class="checkout-modal-overlay">
    <div class="checkout-modal">
      <div class="checkout-modal-header">
        <h3>Complete Order</h3>
        <button class="checkout-modal-close cart-close" aria-label="Close checkout">
          <i data-lucide="x" style="width:20px;height:20px;"></i>
        </button>
      </div>
      
      <!-- Order Summary -->
      <div class="checkout-summary">
        <div class="checkout-summary-title">Your Items</div>
        <div class="checkout-summary-list"></div>
        <div class="checkout-summary-divider"></div>
        <div class="checkout-summary-item">
          <span class="checkout-summary-item-name" style="font-weight:700;">Total</span>
          <span class="checkout-summary-total" style="font-family:var(--font-heading);font-size:1.1rem;font-weight:700;color:var(--caramel);">$0.00</span>
        </div>
      </div>
      
      <form id="checkout-form" class="checkout-form">
        <div class="form-group">
          <label for="checkout-name">Name</label>
          <input type="text" id="checkout-name" name="name" placeholder="Your full name" required>
          <div class="form-error"></div>
        </div>
        <div class="form-group">
          <label for="checkout-phone">Phone</label>
          <input type="tel" id="checkout-phone" name="phone" placeholder="(425) 555-0000" required>
          <div class="form-error"></div>
        </div>
        <div class="form-group">
          <label for="checkout-time">Pickup Time</label>
          <select id="checkout-time" name="time">
            <option value="asap">As soon as possible</option>
            <option value="30min">In 30 minutes</option>
            <option value="1hr">In 1 hour</option>
            <option value="90min">In 1.5 hours</option>
          </select>
        </div>
        <div class="form-group">
          <label for="checkout-notes">Special Instructions</label>
          <textarea id="checkout-notes" name="notes" placeholder="Any allergies or preferences..." rows="3"></textarea>
        </div>
        <button type="submit" class="checkout-submit">Confirm Order</button>
      </form>
      <div class="order-confirmation">
        <div class="order-confirmation-icon">
          <i data-lucide="check" style="width:32px;height:32px;"></i>
        </div>
        <h3>Order Placed!</h3>
        <p>We're preparing your order. We'll call you shortly to confirm.</p>
      </div>
    </div>
  </div>

  <!-- Floating Buttons -->
